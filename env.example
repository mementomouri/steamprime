# SMS.ir Configuration
# این فایل را کپی کرده و نام آن را به .env.local تغییر دهید
# سپس مقادیر واقعی خود را وارد کنید

# کلید API خود را از پنل SMS.ir دریافت کنید
SMS_IR_API_KEY=e5zgPqeY2YaPwPXRGaoF1kgnfRHHLDFqIGSjgV981WB4JV6y

# شماره الگوی SMS که در SMS.ir ایجاد کرده‌اید
# این الگو باید شامل پارامتر CODE باشد
SMS_IR_TEMPLATE_ID=100000

# مثال:
# SMS_IR_API_KEY=e5zgPqeY2YaPwPXRGaoF1kgnfRHHLDFqIGSjgV981WB4JV6y
# SMS_IR_TEMPLATE_ID=123456 